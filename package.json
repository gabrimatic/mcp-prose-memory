{
  "name": "mcp-prose-memory",
  "version": "3.0.0",
  "description": "MCP server for persistent memory with JSON storage and atomic fact operations",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-prose-memory": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test tests/*.test.mjs",
    "audit:prod": "npm audit --omit=dev",
    "check": "npm run test && npm run audit:prod && npm pack --dry-run",
    "prepare": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "memory",
    "json",
    "persistent"
  ],
  "author": "Soroush (https://gabrimatic.info)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrimatic/mcp-prose-memory.git"
  },
  "bugs": {
    "url": "https://github.com/gabrimatic/mcp-prose-memory/issues"
  },
  "homepage": "https://gabrimatic.github.io/mcp-prose-memory/"
}
